<?xml version="1.0" encoding="UTF-8"?>
<!--
  IIS Reverse Proxy configuration — requires:
    1. URL Rewrite module  (download from iis.net)
    2. Application Request Routing (ARR)  (download from iis.net)

  After installing both modules:
    - Open IIS Manager > server node > Application Request Routing Cache
    - Click "Server Proxy Settings" and enable the proxy
    - Deploy this web.config to the IIS site root
    - Node.js must be running on the port defined in config.json (default 3001)

  To run Node.js as a Windows service (so it starts automatically):
    npm install -g pm2
    pm2 start server.js --name webstatus
    pm2-startup install   (or use NSSM / Task Scheduler)
-->
<configuration>
  <system.webServer>

    <rewrite>
      <rules>
        <rule name="WebStatus Node.js Proxy" stopProcessing="true">
          <match url="(.*)" />
          <conditions>
            <!-- Don't rewrite requests for actual static files that IIS should serve directly -->
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
          </conditions>
          <action type="Rewrite" url="http://localhost:3001/{R:1}" />
        </rule>
      </rules>
    </rewrite>

    <!-- Pass the original host header so Node.js sees the real hostname -->
    <proxy enabled="true" preserveHostHeader="true" />

  </system.webServer>
</configuration>
